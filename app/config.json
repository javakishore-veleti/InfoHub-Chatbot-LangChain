{
  "default_workflow": {
    "parent": "ingest",
    "child": "AWSBedrock"
  },
  "workflows": {
    "ingest": {
      "default_child": "AWSBedrock",
      "children": {
        "AWSBedrock": {
          "workflow_id": "ingest_001",
