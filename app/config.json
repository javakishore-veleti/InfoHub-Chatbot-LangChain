          "allowed_domains": [
            "docs.aws.amazon.com"
          ],
          "allowed_path_prefixes": [
            "/bedrock/latest/userguide/"
          ],
          "max_tokens": 400,
          "overlap_tokens": 40,
          "max_pages": 30,
          "max_depth": 2,
          "timeout_seconds": 20,
          "chunking_methods": [
            "fixed_token",
            "sliding_window_overlap",
            "sentence",
            "paragraph_section",
            "semantic",
            "hierarchical",
            "query_aware"
          ],
          "query_terms": [
            "knowledge base",
            "foundation model",
            "guardrails"
          ],
          "ui": {
