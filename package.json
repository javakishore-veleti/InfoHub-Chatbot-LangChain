 {
  "name": "infohub-chatbot-langchain",
  "private": true,
  "version": "0.1.0",
  "description": "Command runner scripts for local uv environment setup",
  "scripts": {
    "setup:local:init": "npm run setup:local:venv:setup && npm run setup:local:sync && npm run setup:local:status",
    "setup:local:venv:setup": "npm run venv:setup",
    "setup:local:venv:activate": "npm run venv:activate",
    "setup:local:venv:deactivate": "npm run venv:deactivate",
    "setup:local:venv:deactivatte": "npm run venv:deactivate",
    "setup:local:status": "npm run venv:status",
    "setup:local:destroy": "npm run venv:destroy",
    "setup:local:sync": "npm run uv:sync",
    "setup:local:python:version": "npm run uv:python:version",
    "setup:local:deps:check": "npm run uv:deps:check",
    "setup:local:ingest:run": "npm run ingest:run",
    "setup:local:ingest:run:json": "npm run ingest:run:json",
    "setup:local:ingest:run:fetch-again": "npm run ingest:run:fetch-again",
    "setup:local:workflow:run": "npm run workflow:run",
    "setup:local:api:start": "npm run start:api",
    "setup:local:ui:start": "npm run start:ui",
    "setup:local:api-ui:start": "npm run start:api-ui",
    "venv:setup": "bash ./scripts/local-env.sh setup",
    "venv:activate": "bash ./scripts/local-env.sh activate",
    "venv:deactivate": "bash ./scripts/local-env.sh deactivate",
    "venv:status": "bash ./scripts/local-env.sh status",
    "venv:destroy": "bash ./scripts/local-env.sh destroy",
    "uv:sync": "bash ./scripts/local-env.sh sync",
    "uv:python:version": "bash ./scripts/local-env.sh python-version",
    "uv:deps:check": "bash ./scripts/local-env.sh deps-check",
    "ingest:run": "uv run --active python -m app.main",
    "ingest:run:json": "uv run --active python -m app.main --json",
    "ingest:run:fetch-again": "uv run --active python -m app.main --fetch-again --json",
    "workflow:run": "uv run --active python -m app.main --workflow ingest",
    "start:api": "bash ./scripts/start-api.sh",
    "start:ui": "bash ./scripts/start-ui.sh",
    "start:api-ui": "bash ./scripts/start-api-ui.sh",
    "start:api:ps": "powershell -ExecutionPolicy Bypass -File ./scripts/start-api.ps1",
    "start:ui:ps": "powershell -ExecutionPolicy Bypass -File ./scripts/start-ui.ps1",
    "start:api-ui:ps": "powershell -ExecutionPolicy Bypass -File ./scripts/start-api-ui.ps1",
    "start:api-ui:docker": "bash ./scripts/start-api-ui-docker.sh",
    "start:api-ui:docker:ps": "powershell -ExecutionPolicy Bypass -File ./scripts/start-api-ui-docker.ps1",
    "stop:api-ui": "bash ./scripts/stop-api-ui.sh",
    "stop:api-ui:ps": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-api-ui.ps1",
    "stop:api-ui:docker": "bash ./scripts/stop-api-ui-docker.sh",
    "stop:api-ui:docker:ps": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-api-ui-docker.ps1",
    "devops:docker:start-all": "bash ./DevOps/Local/docker-all-up.sh",
    "devops:docker:stop-all": "bash ./DevOps/Local/docker-all-down.sh",
    "devops:docker:status-all": "bash ./DevOps/Local/docker-all-status.sh"
  }
}

